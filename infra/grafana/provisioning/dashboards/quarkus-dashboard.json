    {
      "title": "System CPU & Load",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "system_cpu_usage{application=\"quarkus-boilerplate\"}",
