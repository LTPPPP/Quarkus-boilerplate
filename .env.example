# ============================================================
# QUARKUS ENTERPRISE BOILERPLATE - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# For production, use a secrets manager (Vault, AWS Secrets Manager, etc.)
#
# Profiles: LOCAL | DOCKER | STAGING | PRODUCTION
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
APP_PROFILE=dev
QUARKUS_HTTP_PORT=8080
QUARKUS_LOG_LEVEL=INFO

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_POOL_SIZE=20
DB_MIN_POOL_SIZE=5

# Connection pool tuning (production)
# DB_MAX_POOL_SIZE=50
# DB_MIN_POOL_SIZE=10
# DB_IDLE_TIMEOUT=PT10M
# DB_MAX_LIFETIME=PT30M
# DB_VALIDATION_QUERY_SQL=SELECT 1

# Read replicas (horizontal scaling)
# DB_REPLICA_HOST=replica.db.internal
# DB_REPLICA_PORT=5432

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_MAX_POOL_SIZE=16
REDIS_TIMEOUT=5S

# Redis Sentinel (HA mode)
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# Redis Cluster
# REDIS_CLUSTER_HOSTS=node1:6379,node2:6379,node3:6379

# ============================================================
# KAFKA
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# Kafka tuning
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=5
KAFKA_CONSUMER_MAX_POLL_RECORDS=500
KAFKA_CONSUMER_SESSION_TIMEOUT_MS=30000

# Kafka SSL (production)
# KAFKA_SECURITY_PROTOCOL=SSL
# KAFKA_SSL_TRUSTSTORE_LOCATION=/certs/kafka.truststore.jks
# KAFKA_SSL_TRUSTSTORE_PASSWORD=changeit
# KAFKA_SSL_KEYSTORE_LOCATION=/certs/kafka.keystore.jks
# KAFKA_SSL_KEYSTORE_PASSWORD=changeit

# Kafka SASL (production)
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="app" password="secret";

# ============================================================
# JWT / SECURITY
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRY_SECONDS=3600
JWT_REFRESH_EXPIRY_SECONDS=86400
JWT_ISSUER=https://your-domain.example.com

# ============================================================
# gRPC
# ============================================================
GRPC_PORT=9000
GRPC_USER_SERVICE_HOST=localhost
GRPC_USER_SERVICE_PORT=9000
GRPC_PAYMENT_SERVICE_HOST=localhost
GRPC_PAYMENT_SERVICE_PORT=9000
GRPC_MAX_INBOUND_MESSAGE_SIZE=4194304

# gRPC TLS (production)
# GRPC_TLS_CERT=/certs/server.crt
# GRPC_TLS_KEY=/certs/server.key
# GRPC_TLS_CA=/certs/ca.crt

# ============================================================
# MULTI-TENANCY
# ============================================================
MULTITENANCY_STRATEGY=SCHEMA
MULTITENANCY_DEFAULT_SCHEMA=public
MULTITENANCY_CACHE_TTL=PT30M

# ============================================================
# ENCRYPTION
# ============================================================
ENCRYPTION_KEY=change-this-default-key-32chars!

# ============================================================
# OBSERVABILITY - OpenTelemetry
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=quarkus-boilerplate
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=false

# ============================================================
# OBSERVABILITY - Prometheus / Grafana
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================
# RATE LIMITING (scale-up)
# ============================================================
# RATE_LIMIT_REQUESTS_PER_SECOND=100
# RATE_LIMIT_BURST_SIZE=200
# RATE_LIMIT_PER_TENANT=true

# ============================================================
# KUBERNETES / DEPLOYMENT (production)
# ============================================================
# K8S_NAMESPACE=myapp-production
# K8S_REPLICAS=3
# K8S_CPU_REQUEST=500m
# K8S_CPU_LIMIT=2000m
# K8S_MEMORY_REQUEST=512Mi
# K8S_MEMORY_LIMIT=2Gi

# HEALTH_CHECK_PATH=/q/health
# READINESS_PATH=/q/health/ready
# LIVENESS_PATH=/q/health/live

# ============================================================
# FEATURE FLAGS (scale-up)
# ============================================================
# FF_ENABLE_ASYNC_PROCESSING=true
# FF_ENABLE_CIRCUIT_BREAKER=true
# FF_ENABLE_REQUEST_CACHING=true
# FF_ENABLE_GRPC_GATEWAY=true
# FF_ENABLE_OUTBOX_POLLER=true
